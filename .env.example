# ============================================================
# 环境变量配置模板 / Environment Variables Template
# ============================================================
# 复制此文件为 .env 并填入真实值 / Copy to .env and fill in real values
# 警告：.env 文件绝对不能提交到 Git！/ WARNING: Never commit .env to Git!
# ============================================================

# ------------------------------------------------------------
# Privy 配置 / Privy Configuration
# 从 https://dashboard.privy.io 获取 / Get from https://dashboard.privy.io
# ------------------------------------------------------------

# Privy App ID（公开值，前端也可用）/ Privy App ID (public, safe for frontend)
PRIVY_APP_ID=your_privy_app_id_here

# Privy App Secret（服务端私密，绝不能暴露给前端）/ Privy App Secret (server-only, never expose to frontend)
PRIVY_APP_SECRET=your_privy_app_secret_here

# P256 授权私钥（wallet-auth: 前缀 + base64 编码的 PKCS8 DER）
# 通过 python scripts/generate_auth_key.py 生成
# P256 authorization private key (wallet-auth: prefix + base64 PKCS8 DER)
# Generate with: python scripts/generate_auth_key.py
PRIVY_AUTHORIZATION_KEY=wallet-auth:your_base64_pkcs8_private_key_here

# Key Quorum ID（在 Privy Dashboard 注册公钥后获得）
# Key Quorum ID (obtained after registering public key in Privy Dashboard)
PRIVY_KEY_QUORUM_ID=your_key_quorum_id_here

# ------------------------------------------------------------
# Polymarket / CLOB API 配置 / Polymarket / CLOB API Configuration
# ------------------------------------------------------------

# Polygon 主网 RPC URL / Polygon mainnet RPC URL
POLYMARKET_RPC_URL=https://polygon-rpc.com

# 链 ID（137 = Polygon 主网）/ Chain ID (137 = Polygon mainnet)
POLYMARKET_CHAIN_ID=137

# Polymarket CLOB API 地址 / Polymarket CLOB API host
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Polymarket CTF Exchange 合约地址（Polygon 主网）
# Polymarket CTF Exchange contract address (Polygon mainnet)
POLYMARKET_CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# Polymarket NegRisk CTF Exchange 合约地址（多结果市场用）
# Polymarket NegRisk CTF Exchange contract address (for multi-outcome markets)
POLYMARKET_NEG_RISK_CTF_EXCHANGE_ADDRESS=0xC5d563A36AE78145C45a50134d48A1215220f80a

# Polymarket NegRisk Adapter 合约地址（CLOB 验证 neg_risk 余额时同时检查此地址）
# Polymarket NegRisk Adapter contract address (CLOB also checks allowance to this for neg_risk markets)
POLYMARKET_NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296

# ------------------------------------------------------------
# Builder API 凭据（Polymarket Builder 方案下单时需要）
# Builder API Credentials (required for Builder scheme order placement)
# 申请地址 / Apply at: https://docs.polymarket.com/developers/builders/builder-profile
# ------------------------------------------------------------

# Builder API Key
POLYMARKET_BUILDER_API_KEY=your_builder_api_key_here

# Builder API Secret（用于 HMAC-SHA256 签名）/ Builder API Secret (for HMAC-SHA256 signing)
POLYMARKET_BUILDER_SECRET=your_builder_secret_here

# Builder API Passphrase
POLYMARKET_BUILDER_PASSPHRASE=your_builder_passphrase_here

# ------------------------------------------------------------
# Safe 合约地址（Polygon mainnet，通常无需修改）
# Safe Contract Addresses (Polygon mainnet, usually no need to change)
# ------------------------------------------------------------

# Polymarket 专用 SafeFactory 地址（Polygon mainnet + Amoy，非标准 Gnosis ProxyFactory！）
# Polymarket-specific SafeFactory address (Polygon mainnet + Amoy, NOT the standard Gnosis ProxyFactory!)
SAFE_PROXY_FACTORY_ADDRESS=0xaacFeEa03eb1561C4e67d661e40682Bd20E3541b

# USDC.e 合约地址（Polygon 主网）/ USDC.e contract address (Polygon mainnet)
USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# Polymarket Relayer API 地址 / Polymarket Relayer API host
RELAYER_HOST=https://relayer-v2.polymarket.com

# ------------------------------------------------------------
# FastAPI 服务器配置 / FastAPI Server Configuration
# ------------------------------------------------------------

# 服务器监听地址 / Server host
API_HOST=0.0.0.0

# 服务器监听端口 / Server port
API_PORT=8000

# 是否开启调试模式 / Enable debug mode
DEBUG=true
